#!/usr/bin/env bash

set -euo pipefail

DAT_HOME="${DAT_HOME:-$HOME/.local/share/dat}"
DAT_BRANCH="${DAT_BRANCH:-main}"

if [[ ! -d "$DAT_HOME/.git" ]]; then
  echo "dat is not installed at $DAT_HOME" >&2
  exit 1
fi

branch="$(git -C "$DAT_HOME" rev-parse --abbrev-ref HEAD)"
commit="$(git -C "$DAT_HOME" rev-parse --short HEAD)"

if [[ -n "$(git -C "$DAT_HOME" status --porcelain)" ]]; then
  dirty="yes"
else
  dirty="no"
fi

ahead="0"
behind="0"
if git -C "$DAT_HOME" show-ref --verify --quiet "refs/remotes/origin/$DAT_BRANCH"; then
  counts="$(git -C "$DAT_HOME" rev-list --left-right --count "HEAD...origin/$DAT_BRANCH")"
  read -r ahead behind <<<"$counts"
fi

echo "path: $DAT_HOME"
echo "branch: $branch"
echo "commit: $commit"
echo "dirty: $dirty"
echo "ahead: $ahead"
echo "behind: $behind"
