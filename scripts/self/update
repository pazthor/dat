#!/usr/bin/env bash

set -euo pipefail

DAT_HOME="${DAT_HOME:-$HOME/.local/share/dat}"
DAT_BRANCH="${DAT_BRANCH:-main}"

usage() {
  cat <<'EOF'
Update dat from origin/main using fast-forward only.

Usage:
  update
  update --check
  update -h | --help
EOF
}

check_only=false

while [[ $# -gt 0 ]]; do
  case "$1" in
  --check)
    check_only=true
    ;;
  -h|--help)
    usage
    exit 0
    ;;
  *)
    echo "Unknown option: $1" >&2
    usage >&2
    exit 1
    ;;
  esac
  shift
done

if [[ ! -d "$DAT_HOME/.git" ]]; then
  echo "dat is not installed at $DAT_HOME" >&2
  exit 1
fi

git -C "$DAT_HOME" fetch origin "$DAT_BRANCH"

counts="$(git -C "$DAT_HOME" rev-list --left-right --count "HEAD...origin/$DAT_BRANCH")"
read -r ahead behind <<<"$counts"

if $check_only; then
  if [[ "$ahead" -eq 0 && "$behind" -eq 0 ]]; then
    echo "dat is up to date ($DAT_BRANCH @ $(git -C "$DAT_HOME" rev-parse --short HEAD))"
  else
    echo "dat update available: ahead=$ahead behind=$behind"
  fi
  exit 0
fi

if [[ -n "$(git -C "$DAT_HOME" status --porcelain)" ]]; then
  echo "Working tree is dirty in $DAT_HOME. Commit or stash changes before updating." >&2
  exit 1
fi

current_branch="$(git -C "$DAT_HOME" rev-parse --abbrev-ref HEAD)"
if [[ "$current_branch" != "$DAT_BRANCH" ]]; then
  echo "Current branch is '$current_branch'. Switch to '$DAT_BRANCH' before updating." >&2
  exit 1
fi

if [[ "$ahead" -gt 0 && "$behind" -gt 0 ]]; then
  echo "Local branch diverged from origin/$DAT_BRANCH. Resolve divergence before updating." >&2
  exit 1
fi

if [[ "$behind" -eq 0 ]]; then
  echo "dat is already up to date ($DAT_BRANCH @ $(git -C "$DAT_HOME" rev-parse --short HEAD))"
  exit 0
fi

old_sha="$(git -C "$DAT_HOME" rev-parse --short HEAD)"
git -C "$DAT_HOME" pull --ff-only origin "$DAT_BRANCH"
new_sha="$(git -C "$DAT_HOME" rev-parse --short HEAD)"

chmod +x "$DAT_HOME/bin/dat"
echo "dat updated: $old_sha -> $new_sha"
